{
  "manifest_version": 3,
  "name": "Manum",
  "version": "0.0.4",
  "description": "Track and attribute AI-assisted writing",
  "permissions": ["storage", "unlimitedStorage", "tabs", "clipboardRead", "offscreen"],
  "host_permissions": ["*://claude.ai/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["offscreen/offscreen.html", "editor/index.html", "editor/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Manum Editor",
    "default_popup": "editor/index.html"
  }
}
